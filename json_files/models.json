        {
            "model_name": "Robot",
            "description": "The following example models a robot moving along a path while receiving possibly inconsistent information about obstacles. To reflect disagreements between sensors, the model uses two groups: \"positive sensors\", which provide evidence that the path is clear, and \"negative sensors\", which provide evidence that it is obstructed. Each sensor outputs a value in {0, 1/2, 1}, where 0 denotes falsity, 1 truth, and 1/2 uncertainty. The Robot PLTS consists of four checkpoints (states) connected by the action \u201cmove\u201d. Each transition is weighted by a pair (tt, ff), where tt represents the evidence from the positive sensors that the path is clear, and ff represents the evidence from the negative sensors that it is obstructed. In addition, the proposition \u201cObst\u201d indicates whether a checkpoint contains an obstacle: it has value (1, 0) only at v3, and (0, 1) elsewhere.",
            "twist_structure_name": "Nine",
            "worlds": [
                "v3",
                "v2",
                "v1",
                "v4"
            ],
            "accessibility_relations": {
                "move": {
                    "v1": {
                        "v1": ["0", "1"],
                        "v2": ["1", "0"],
                        "v3": ["1", "1"],
                        "v4": ["0", "1"]
                    },
                    "v2": {
                        "v1": ["1", "0"],
                        "v2": ["0", "1"],
                        "v3": ["0", "1"],
                        "v4": ["1/2", "0"]
                    },
                    "v3": {
                        "v1": ["0", "1"],
                        "v2": ["0", "1"],
                        "v3": ["0", "1"],
                        "v4": ["0", "1"]
                    },
                    "v4": {
                        "v1": ["0", "1"],
                        "v2": ["1/2", "0"],
                        "v3": ["1/2", "1"],
                        "v4": ["0", "1"]
                    }
                }
            },
            "props": ["Obst"]
        },
